{
  "name": "uace-mcp",
  "version": "0.2.0",
  "description": "Universal AI Context Engine — local-first shared project memory served to any MCP-capable AI assistant.",
  "type": "module",
  "license": "MIT",
  "author": "shivamgupta1319",
  "homepage": "https://github.com/shivamgupta1319/UACE#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shivamgupta1319/UACE.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "memory",
    "context",
    "claude",
    "cursor",
    "copilot",
    "embeddings",
    "local-first"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "uace-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "smoke": "tsx scripts/smoke.ts && tsx scripts/smoke-cli.ts && tsx scripts/smoke-hostconfig.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "simple-git": "^3.25.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
